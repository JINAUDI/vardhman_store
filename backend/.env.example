PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/radios
START_WITHOUT_MONGO=false
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
FRONTEND_ORIGIN=http://127.0.0.1:5500
ADMIN_ORIGIN=http://localhost:3000

# Optional: lets the backend update Supabase order rows with Shiprocket IDs/status.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Shiprocket API user credentials. Create these in Shiprocket Settings > API.
SHIPROCKET_API_EMAIL=your-shiprocket-api-user@example.com
SHIPROCKET_API_PASSWORD=your-shiprocket-api-password
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external
SHIPROCKET_DEFAULT_LENGTH_CM=10
SHIPROCKET_DEFAULT_BREADTH_CM=10
SHIPROCKET_DEFAULT_HEIGHT_CM=10
SHIPROCKET_DEFAULT_WEIGHT_KG=0.5
